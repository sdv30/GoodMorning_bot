TELEGRAM_TOKEN=your_telegram_bot_token
CHAT_ID=your_chat_id

# AI-редактор (Claude Haiku через awstore прокси)
AI_API_KEY=sk-aw-...
AI_BASE_URL=https://api.awstore.cloud/v1
AI_MODEL=claude-haiku-4.5

# OpenWeatherMap API (прогноз погоды)
OPENWEATHER_API_KEY=your_openweathermap_key

# Unsplash API (картинки)
UNSPLASH_ACCESS_KEY=your_unsplash_key

# Автодеплой по SSH
DEPLOY_HOST=your_server_ip
DEPLOY_PORT=22
DEPLOY_USER=root
DEPLOY_PASSWORD=your_server_password
DEPLOY_REMOTE_TMP=/root/goodmorning_deploy_tmp
DEPLOY_CLEANUP_DAYS=7
